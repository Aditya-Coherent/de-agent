# Copy to .env and fill in your key.

OPENROUTER_API_KEY=sk-or-v1-...

# Model selection
# openai/gpt-4o-mini  — uses local SQLite cache (fast, cheap re-runs)
# deepseek/deepseek-chat — live calls + DDG evidence (needs outbound HTTP)
ME_CURVE_MODEL=openai/gpt-4o-mini

ME_LLM_BASE_URL=https://openrouter.ai/api/v1
ME_LLM_TIMEOUT=90

# Evidence Agent (DDG web searches)
# Set to 1 when outbound network is available
ME_ENABLE_WEB_EVIDENCE=0
ME_EVIDENCE_CONFIDENCE_THRESHOLD=0.65
ME_EVIDENCE_MAX_RESULTS=6
